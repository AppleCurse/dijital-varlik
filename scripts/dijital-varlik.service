[Unit]
Description=Dijital Varlik — Otonom AI Organizmasi
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=administrator
WorkingDirectory=/home/administrator/dijital-varlik
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
